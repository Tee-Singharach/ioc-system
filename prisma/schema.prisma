// IOC System — MySQL schema (SPEC: ฟอร์มมาตรฐาน + workflow 5 ขั้น)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  staff
  officer
  manager
  admin
}

enum TicketStatus {
  WAITING_ACK      @map("รอรับเรื่อง")
  PENDING_APPROVAL @map("รออนุมัติ")
  IN_PROGRESS      @map("กำลังดำเนินการ")
  COMPLETED        @map("เสร็จสมบูรณ์")
  REJECTED         @map("ปฏิเสธ")
  CANCELLED        @map("ยกเลิก")
}

enum Priority {
  LOW    @map("ต่ำ")
  MEDIUM @map("ปานกลาง")
  HIGH   @map("สูง")
  URGENT @map("เร่งด่วน")
}

model Department {
  id        String    @id @default(cuid())
  name      String
  shortName String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users   User[]
  tickets Ticket[]

  @@map("departments")
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  name         String
  role         UserRole
  departmentId String
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  department       Department         @relation(fields: [departmentId], references: [id])
  requestedTickets Ticket[]           @relation("TicketRequester")
  receivedTickets  Ticket[]           @relation("TicketReceivedBy")
  assignedTickets  Ticket[]           @relation("TicketAssignee")
  evaluations      TicketEvaluation[]
  comments         TicketComment[]
  progressNotes    ProgressNote[]
  auditLogs        AuditLog[]

  @@index([departmentId])
  @@map("users")
}

model Ticket {
  id              String       @id @default(cuid())
  ticketNo        String       @unique
  title           String
  description     String       @db.Text
  priority        Priority
  status          TicketStatus @default(WAITING_ACK)
  departmentId    String
  requesterId     String
  receivedById    String?
  assigneeId      String?
  scheduledStartAt DateTime
  scheduledEndAt   DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  department   Department            @relation(fields: [departmentId], references: [id])
  requester    User                  @relation("TicketRequester", fields: [requesterId], references: [id])
  receivedBy   User?                 @relation("TicketReceivedBy", fields: [receivedById], references: [id])
  assignee     User?                 @relation("TicketAssignee", fields: [assigneeId], references: [id])
  evaluation   TicketEvaluation?
  attachments  TicketAttachment[]
  comments     TicketComment[]
  progressNotes ProgressNote[]
  statusHistory TicketStatusHistory[]

  @@index([departmentId])
  @@index([requesterId])
  @@index([status])
  @@index([receivedById])
  @@index([assigneeId])
  @@map("tickets")
}

model TicketEvaluation {
  id            String   @id @default(cuid())
  ticketId      String   @unique
  diagnosis     String   @db.Text
  estimatedCost Decimal? @db.Decimal(12, 2)
  notes         String?  @db.Text
  evaluatedById String
  evaluatedAt   DateTime @default(now())

  ticket      Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  evaluatedBy User   @relation(fields: [evaluatedById], references: [id])

  @@map("ticket_evaluations")
}

model TicketAttachment {
  id        String   @id @default(cuid())
  ticketId  String
  name      String
  size      Int
  storageKey String?
  url       String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_attachments")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@map("ticket_comments")
}

model ProgressNote {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@map("progress_notes")
}

model TicketStatusHistory {
  id        String       @id @default(cuid())
  ticketId  String
  status    TicketStatus
  note      String?      @db.Text
  at        DateTime     @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_status_history")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  target    String
  actorId   String
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}
